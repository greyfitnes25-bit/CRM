// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERADMIN
  OWNER
  ADMIN
  SELLER
  TECHNICIAN
  SUPPORT
}

enum CustomerSource {
  WHATSAPP
  INSTAGRAM
  MESSENGER
  META_ADS
  WEB
  REFERRAL
  OTHER
}

enum LeadStage {
  NEW_LEAD
  CONTACTED
  QUOTED
  NEGOTIATION
  PENDING_PAYMENT
  SOLD
  LOST
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum SaleStatus {
  PAID
  PENDING
  PARTIAL
  CANCELLED
}

enum InstallationStatus {
  PENDING
  ASSIGNED
  ON_WAY
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum WarrantyStatus {
  ACTIVE
  EXPIRED
  VOIDED
}

enum WarrantyCaseStatus {
  OPEN
  IN_REVIEW
  APPROVED
  REJECTED
  RESOLVED
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum ConversationChannel {
  WHATSAPP
  INSTAGRAM
  MESSENGER
  WEB
}

enum ConversationStatus {
  OPEN
  CLOSED
  PENDING
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum CompanyPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

model Company {
  id             String      @id @default(cuid())
  name           String
  slug           String      @unique
  logo           String?
  primaryColor   String      @default("#3B82F6")
  secondaryColor String      @default("#1E40AF")
  currency       String      @default("USD")
  timezone       String      @default("America/Mexico_City")
  plan           CompanyPlan @default(FREE)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  users         User[]
  customers     Customer[]
  products      Product[]
  leads         Lead[]
  quotes        Quote[]
  sales         Sale[]
  installations Installation[]
  warranties    Warranty[]
  warrantyCases WarrantyCase[]
  returns       Return[]
  conversations Conversation[]
  messages      Message[]
  campaigns     Campaign[]
  quickReplies  QuickReply[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String
  password  String?
  role      UserRole @default(SELLER)
  companyId String
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  accounts      Account[]
  sessions      Session[]
  assignedLeads Lead[]         @relation("LeadAssignee")
  assignedCustmrs Customer[]   @relation("CustomerAssignee")
  assignedQuotes Quote[]       @relation("QuoteAssignee")
  assignedSales  Sale[]        @relation("SaleAssignee")
  techInstalls   Installation[] @relation("TechInstaller")
  assignedCases  WarrantyCase[] @relation("CaseAssignee")
  assignedReturns Return[]     @relation("ReturnAssignee")
  assignedConvos Conversation[] @relation("ConvAssignee")

  @@unique([email, companyId])
}

model Customer {
  id         String         @id @default(cuid())
  name       String
  email      String?
  phone      String?
  whatsapp   String?
  instagram  String?
  address    String?
  city       String?
  source     CustomerSource @default(OTHER)
  tags       String[]       @default([])
  notes      String?
  assignedTo String?
  companyId  String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignee      User?          @relation("CustomerAssignee", fields: [assignedTo], references: [id])
  leads         Lead[]
  quotes        Quote[]
  sales         Sale[]
  installations Installation[]
  warranties    Warranty[]
  warrantyCases WarrantyCase[] @relation("CaseCustomer")
  returns       Return[]
  conversations Conversation[]
}

model Product {
  id                  String   @id @default(cuid())
  name                String
  description         String?
  price               Float
  category            String?
  image               String?
  isAvailable         Boolean  @default(true)
  requiresInstallation Boolean @default(false)
  warrantyMonths      Int      @default(12)
  companyId           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warranties Warranty[]
  returns    Return[]
}

model Lead {
  id             String    @id @default(cuid())
  customerId     String
  stage          LeadStage @default(NEW_LEAD)
  estimatedValue Float?
  source         String?
  assignedTo     String?
  notes          String?
  lastContact    DateTime?
  companyId      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignee User?    @relation("LeadAssignee", fields: [assignedTo], references: [id])
}

model Quote {
  id         String      @id @default(cuid())
  customerId String
  assignedTo String?
  items      Json
  subtotal   Float
  discount   Float       @default(0)
  tax        Float       @default(0)
  total      Float
  status     QuoteStatus @default(DRAFT)
  notes      String?
  companyId  String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignee User?    @relation("QuoteAssignee", fields: [assignedTo], references: [id])
  sale     Sale?
}

model Sale {
  id            String     @id @default(cuid())
  customerId    String
  quoteId       String?    @unique
  assignedTo    String?
  items         Json
  total         Float
  paid          Float      @default(0)
  pending       Float      @default(0)
  paymentMethod String?
  status        SaleStatus @default(PENDING)
  companyId     String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer      Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  quote         Quote?         @relation(fields: [quoteId], references: [id])
  assignee      User?          @relation("SaleAssignee", fields: [assignedTo], references: [id])
  installations Installation[]
  warranties    Warranty[]
  returns       Return[]
}

model Installation {
  id          String             @id @default(cuid())
  saleId      String
  customerId  String
  technicianId String?
  scheduledAt DateTime?
  address     String?
  status      InstallationStatus @default(PENDING)
  notes       String?
  evidence    Json?
  companyId   String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sale       Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  technician User?    @relation("TechInstaller", fields: [technicianId], references: [id])
}

model Warranty {
  id        String        @id @default(cuid())
  saleId    String
  customerId String
  productId String
  startDate DateTime
  endDate   DateTime
  status    WarrantyStatus @default(ACTIVE)
  companyId String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  company  Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sale     Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  customer Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  cases    WarrantyCase[]
}

model WarrantyCase {
  id          String             @id @default(cuid())
  warrantyId  String
  customerId  String
  title       String
  description String?
  diagnosis   String?
  solution    String?
  status      WarrantyCaseStatus @default(OPEN)
  assignedTo  String?
  companyId   String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warranty Warranty @relation(fields: [warrantyId], references: [id], onDelete: Cascade)
  customer Customer @relation("CaseCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  assignee User?    @relation("CaseAssignee", fields: [assignedTo], references: [id])
}

model Return {
  id         String       @id @default(cuid())
  saleId     String
  customerId String
  productId  String
  reason     String
  amount     Float
  status     ReturnStatus @default(PENDING)
  notes      String?
  assignedTo String?
  companyId  String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sale     Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  assignee User?    @relation("ReturnAssignee", fields: [assignedTo], references: [id])
}

model Conversation {
  id         String              @id @default(cuid())
  customerId String
  channel    ConversationChannel @default(WHATSAPP)
  status     ConversationStatus  @default(OPEN)
  assignedTo String?
  companyId  String
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignee User?     @relation("ConvAssignee", fields: [assignedTo], references: [id])
  messages Message[]
}

model Message {
  id             String           @id @default(cuid())
  conversationId String
  content        String
  direction      MessageDirection @default(INBOUND)
  senderName     String?
  sentAt         DateTime         @default(now())
  companyId      String

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Campaign {
  id           String   @id @default(cuid())
  name         String
  platform     String
  budget       Float    @default(0)
  spent        Float    @default(0)
  reach        Int      @default(0)
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  ctr          Float    @default(0)
  cpc          Float    @default(0)
  cpm          Float    @default(0)
  leads        Int      @default(0)
  sales        Int      @default(0)
  costPerLead  Float    @default(0)
  costPerSale  Float    @default(0)
  roas         Float    @default(0)
  status       String   @default("ACTIVE")
  startDate    DateTime?
  endDate      DateTime?
  companyId    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model QuickReply {
  id        String   @id @default(cuid())
  title     String
  content   String
  companyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
