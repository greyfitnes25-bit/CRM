# GreyCRM conectado a Supabase
# Copia estos valores a .env cuando tengas tu proyecto de Supabase.

# App normal: usar pooler/session pooler.
DATABASE_URL="postgresql://postgres.PROJECT_REF:TU_PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require&pgbouncer=true"

# Prisma schema changes: usar conexion directa.
DIRECT_URL="postgresql://postgres:TU_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

NEXTAUTH_SECRET="cambia-esto-por-un-secreto-seguro"
NEXTAUTH_URL="http://10.0.0.7:3000"
AUTH_URL="http://10.0.0.7:3000"
AUTH_TRUST_HOST="true"

META_APP_ID=""
META_APP_SECRET=""
META_ACCESS_TOKEN=""
META_AD_ACCOUNT_ID=""
META_WEBHOOK_VERIFY_TOKEN=""
META_PAGE_ID=""
META_WHATSAPP_BUSINESS_ACCOUNT_ID=""
META_PHONE_NUMBER_ID=""

NEXT_PUBLIC_APP_NAME="GreyCRM"
NEXT_PUBLIC_APP_URL="http://10.0.0.7:3000"
