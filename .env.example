# GreyCRM - Variables de Entorno
# Copia este archivo como .env y rellena los valores

# Base de datos PostgreSQL local
DATABASE_URL="postgresql://postgres:TU_PASSWORD@localhost:5432/greycrm"
DIRECT_URL="postgresql://postgres:TU_PASSWORD@localhost:5432/greycrm"

# Supabase PostgreSQL
# DATABASE_URL: usa la URL pooler/session pooler para la app.
# DIRECT_URL: usa la URL directa para prisma db push / migraciones.
# Copia estos valores desde Supabase Project Settings > Database.
# DATABASE_URL="postgresql://postgres.PROJECT_REF:TU_PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require&pgbouncer=true"
# DIRECT_URL="postgresql://postgres:TU_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# NextAuth - genera un secreto seguro con: openssl rand -base64 32
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-seguro"
NEXTAUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# Meta API (dejar vacío hasta conectar)
# Obtenlos en: https://developers.facebook.com
# ─────────────────────────────────────────────
META_APP_ID=""
META_APP_SECRET=""
META_ACCESS_TOKEN=""
META_AD_ACCOUNT_ID=""
META_WEBHOOK_VERIFY_TOKEN=""
META_PAGE_ID=""
META_WHATSAPP_BUSINESS_ACCOUNT_ID=""
META_PHONE_NUMBER_ID=""

# App
NEXT_PUBLIC_APP_NAME="GreyCRM"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
